import socket

# Crear socket
cliente = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)

# Enviar mensaje (sin conexión)
cliente.sendto("Hola servidor UDP".encode(), ("127.0.0.1", 5001))

# Recibir respuesta
respuesta, _ = cliente.recvfrom(1024)
print("Servidor responde:", respuesta.decode())

# Cerrar
cliente.close()