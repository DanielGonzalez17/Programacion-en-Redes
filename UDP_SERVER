import socket

# Crear socket UDP
servidor = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)

# Asociar IP y puerto
servidor.bind(("127.0.0.1", 5001))
print("Servidor UDP esperando mensajes...")

# Recibir mensaje
mensaje, direccion = servidor.recvfrom(1024)
print("Cliente dice:", mensaje.decode())

# Responder al cliente
respuesta = "Mensaje recibido por UDP"
servidor.sendto(respuesta.encode(), direccion)

# Cerrar
servidor.close()